{
    "compilerOptions": {
        "types": ["node", "multer"],
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "noFallthroughCasesInSwitch": false,
        "paths": {
            "@config/*"         : ["./src/config/*"],
            "@common/*"         : ["./src/common/*"],
            "@images/*"         : ["./src/images/*"],
            "@students/*"       : ["./src/students/*"],
            "@send-emails/*"    : ["./src/send-emails/*"],
            "@staff/*"          : ["./src/staff/*"],
            "@templates/*"      : ["./src/templates/*"],
            "@services/*"       : ["./src/services/*"],
            "@prisma/*"         : ["./src/prisma/*"],
            "@app/*"            : ["./src/*"],
        }
    }
}
